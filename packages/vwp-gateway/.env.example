# VWP Gateway environment variables
PORT=3200

# AAC outbound signing secret (used when forwarding to publisher webhooks)
AAC_SIGNING_SECRET=change-me-to-a-secure-random-value

# Provider HMAC keys — set one per enrolled provider (§3.4A)
SIGNING_KEY_ANTHROPIC=change-me
SIGNING_KEY_OPENAI=change-me
SIGNING_KEY_GOOGLE=change-me

# AAC server base URL (for provenance lookups)
AAC_SERVER_URL=http://localhost:3100
