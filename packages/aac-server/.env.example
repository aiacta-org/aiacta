# AAC Server environment variables
# Copy to .env and fill in values before running.

# Database
AAC_DB_PATH=./aac.db            # SQLite path. Use :memory: for tests.

# Server
PORT=3100

# Provenance API key — issued to authorised law enforcement / fact-checkers (§9.5.1)
PROVENANCE_API_KEY=change-me-to-a-secure-random-value

# JWT secret for publisher API authentication (future: replace with OAuth)
API_JWT_SECRET=change-me-to-a-secure-random-value
