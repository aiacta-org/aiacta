{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["aiacta_version", "publisher", "base_url"],
  "properties": {
    "aiacta_version": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "base_url": {
      "type": "string",
      "format": "uri"
    },
    "contact": {
      "type": "string"
    }
  }
}
